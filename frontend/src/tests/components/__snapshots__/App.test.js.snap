// Jest Snapshot v1, https://goo.gl/fbAQLP

exports[`App matches snapshot on auth page and hides header 1`] = `
<div>
  <div
    className="auth-bg"
    style={
      Object {
        "backgroundImage": "url(/background-trainium.png)",
      }
    }
  >
    <div
      className="auth-brand"
    >
      <a
        aria-label="Ir al inicio (Trainium)"
        className="auth-brand-link"
        href="/"
        onClick={[Function]}
      >
        <div
          className="brand-logo-wrapper d-flex align-items-center justify-content-center"
        >
          <img
            alt="Trainium"
            className="brand-logo"
            height="48"
            onError={[Function]}
            src="/trainium-logo-2.png"
            width="48"
          />
        </div>
      </a>
    </div>
    <div
      className="auth-container"
    >
      <div
        className="container signup-container login-container py-5"
      >
        <div
          className="row justify-content-center"
        >
          <div
            className="col-12 col-md-10 col-lg-8 col-xl-6"
          >
            <div
              className="card bg-white border-0 shadow-lg auth-card-dark"
            >
              <h2
                className="card-header text-center mb-0"
              >
                Iniciar sesión
              </h2>
              <div
                className="card-body"
              >
                <form
                  className="needs-validation"
                  noValidate={true}
                  onSubmit={[Function]}
                >
                  <div
                    className="form-row"
                  >
                    <div
                      className="col-md-12 mb-3"
                    >
                      <div
                        className="md-input"
                      >
                        <input
                          autoFocus={true}
                          className="form-control md-control shadow-sm"
                          id="userName"
                          onChange={[Function]}
                          placeholder=" "
                          required={true}
                          type="text"
                          value=""
                        />
                        <label
                          htmlFor="userName"
                        >
                          Nombre de usuario
                        </label>
                        <div
                          className="invalid-feedback"
                        >
                          Campo obligatorio
                        </div>
                      </div>
                    </div>
                  </div>
                  <div
                    className="form-row"
                  >
                    <div
                      className="col-md-12 mb-3"
                    >
                      <div
                        className="md-input"
                      >
                        <input
                          className="form-control md-control shadow-sm"
                          id="password"
                          onChange={[Function]}
                          placeholder=" "
                          required={true}
                          type="password"
                          value=""
                        />
                        <label
                          htmlFor="password"
                        >
                          Contraseña
                        </label>
                        <div
                          className="invalid-feedback"
                        >
                          Campo obligatorio
                        </div>
                      </div>
                    </div>
                  </div>
                  <div
                    className="form-row mt-2"
                  >
                    <div
                      className="col-md-12"
                    >
                      <button
                        aria-label={null}
                        className="trainium-btn trainium-btn--primary trainium-btn--md trainium-btn--full-width"
                        disabled={false}
                        id="loginButton"
                        onClick={null}
                        style={Object {}}
                        type="submit"
                      >
                        <span
                          className="trainium-btn__text"
                        >
                          Iniciar sesión
                        </span>
                      </button>
                    </div>
                  </div>
                  <p
                    className="mt-3 text-center mb-0 auth-alt small"
                  >
                    ¿No tienes cuenta aún?
                     
                    <a
                      className="ms-1"
                      href="/users/signup"
                      onClick={[Function]}
                    >
                      Regístrate
                    </a>
                  </p>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div
      className="footer-auth"
    >
      <footer>
        <p
          className="text-center"
        >
          © Trainium 2025
        </p>
      </footer>
    </div>
  </div>
  <section
    aria-atomic="false"
    aria-label="Notifications Alt+T"
    aria-live="polite"
    aria-relevant="additions text"
    className="Toastify"
    onMouseEnter={[Function]}
    onMouseLeave={[Function]}
  />
</div>
`;
